<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{ifset title}{include title|stripHtml} | {/ifset}SKP Admin</title>

  <!-- Google Font: Source Sans Pro -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
  <!-- Font Awesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
  <!-- Theme style -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">
  {ifset head}{include head}{/ifset}
</head>
<body class="hold-transition sidebar-mini">
<div class="wrapper">

  <!-- Navbar -->
  <nav class="main-header navbar navbar-expand navbar-white navbar-light">
    <!-- Left navbar links -->
    <ul class="navbar-nav">
      <li class="nav-item">
        <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
      </li>
      <li class="nav-item d-none d-sm-inline-block">
        <a n:href=":Front:Home:" class="nav-link" target="_blank">Přejít na web</a>
      </li>
    </ul>

    <!-- Right navbar links -->
    <ul class="navbar-nav ml-auto">
      {ifset $availablePresentations}
      <li class="nav-item d-flex align-items-center">
        <label class="text-muted mr-2 mb-0 d-none d-sm-inline">Aktivní prezentace:</label>
        <select class="form-control form-control-sm" style="width: auto; min-width: 150px;"
                onchange="window.location.href = this.value">
          <option n:foreach="$availablePresentations as $pid => $pres"
                  value="{link switchPresentation!, id => $pid}"
                  n:attr="selected => $loggedUserEntity->active_presentation_id == $pid">
            {$pres->presentation_name} ({$pres->domain})
          </option>
          <option n:if="!$availablePresentations" disabled selected>Žádné prezentace</option>
        </select>
      </li>
      {/ifset}
    </ul>
  </nav>
  <!-- /.navbar -->

  <!-- Main Sidebar Container -->
  <aside class="main-sidebar sidebar-dark-primary elevation-4">
    <!-- Brand Logo -->
    <a href="#" class="brand-link">
      <span class="brand-text font-weight-light">SKP Admin</span>
    </a>

    <!-- Sidebar -->
    <div class="sidebar">
      <!-- Sidebar Menu -->
      <nav class="mt-2">
        <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
          <li class="nav-item">
            <a n:href="Dashboard:, id => null, spec_param_id => null" class="nav-link {if $presenter->isLinkCurrent('Dashboard:*')}active{/if}">
              <i class="nav-icon fas fa-tachometer-alt"></i>
              <p>Dashboard</p>
            </a>
          </li>
          <li class="nav-item">
            <a  n:if="$loggedUserEntity->hasGroupRight('PAGES')"  n:href="Pages:, id => null, spec_param_id => null" class="nav-link {if $presenter->isLinkCurrent('Pages:*')}active{/if}">
              <i class="nav-icon fas fa-file-alt"></i>
              <p>Stránky</p>
            </a>
          </li>
          <li class="nav-item">
            <a n:if="$loggedUserEntity->hasGroupRight('ACCOUNTS')"  n:href="Accounts:, id => null, spec_param_id => null" class="nav-link {if $presenter->isLinkCurrent('Accounts:*')}active{/if}">
              <i class="nav-icon fas fa-users"></i>
              <p>Účty</p>
            </a>
          </li>
          <li class="nav-item {if $presenter->isPresenter('Presentation') || $presenter->isPresenter('Config') || $presenter->isPresenter('Lookup') || $presenter->isPresenter('Template') || $presenter->isPresenter('Install') || $presenter->isPresenter('Log')}menu-open{/if}">
            <a n:if="$loggedUserEntity->hasGroupRight('CONFIG')" href="#" class="nav-link {if $presenter->isPresenter('Presentation') || $presenter->isPresenter('Config') || $presenter->isPresenter('Lookup') || $presenter->isPresenter('Template') || $presenter->isPresenter('Install') || $presenter->isPresenter('Log')}active{/if}">
              <i class="nav-icon fas fa-cog"></i>
              <p>
                Nastavení
                <i class="right fas fa-angle-left"></i>
              </p>
            </a>
            <ul class="nav nav-treeview">
              <li class="nav-item">
                <a  n:if="$loggedUserEntity->hasGroupRight('PRESENTATION')" n:href="Presentation:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Presentation')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Prezentace</p>
                </a>
              </li>
              <li class="nav-item">
                <a  n:if="$loggedUserEntity->hasGroupRight('SYSTEM_CONFIG')"  n:href="Config:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Config')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Nastavení systému</p>
                </a>
              </li>
              <li class="nav-item">
                <a  n:if="$loggedUserEntity->hasGroupRight('LOOKUP')" n:href="Lookup:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Lookup')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Číselníky</p>
                </a>
              </li>
              <li class="nav-item">
                <a  n:if="$loggedUserEntity->hasGroupRight('TEMPLATES')"  n:href="Template:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Template')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Šablony</p>
                </a>
              </li>
              <li class="nav-item">
                <a n:if="$loggedUserEntity->hasGroupRight('INSTALL_MODULE')"  n:href="Install:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Install')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Instalované moduly</p>
                </a>
              </li>
            </ul>
          </li>
          <li n:if="$loggedUserEntity->hasGroupRight('GROUPS') or $loggedUserEntity->hasGroupRight('RIGHTS') or $loggedUserEntity->hasGroupRight('PAGE_GROUP')" class="nav-item {if $presenter->isPresenter('Groups') || $presenter->isPresenter('ModuleRights') || $presenter->isPresenter('PageGroups')}menu-open{/if}">
            <a   href="#" class="nav-link {if $presenter->isPresenter('Groups') || $presenter->isPresenter('ModuleRights') || $presenter->isPresenter('PageGroups')}active{/if}">
              <i class="nav-icon fas fa-user-shield"></i>
              <p>
                Práva
                <i class="right fas fa-angle-left"></i>
              </p>
            </a>
            <ul class="nav nav-treeview">
              <li class="nav-item">
                <a n:if="$loggedUserEntity->hasGroupRight('GROUPS')" n:href="Groups:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Groups')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Skupiny</p>
                </a>
              </li>
              <li class="nav-item">
                <a n:if="$loggedUserEntity->hasGroupRight('RIGHTS')" n:href="ModuleRights:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('ModuleRights')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Práva modulů</p>
                </a>
              </li>
              <li class="nav-item">
                <a n:if="$loggedUserEntity->hasGroupRight('PAGE_GROUP')"  n:href="PageGroups:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('PageGroups')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Skupina stránek</p>
                </a>
              </li>
            </ul>
          </li>
          <li class="nav-item">
            <a n:if="$loggedUserEntity->hasGroupRight('TOOLS')" n:href="Tools:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Tools')}active{/if}">
              <i class="nav-icon fas fa-tools"></i>
              <p>Nástroje</p>
            </a>
          </li>
          <li class="nav-item">
            <a n:if="$loggedUserEntity->hasGroupRight('FILEMANAGER')" n:href="Files:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Files')}active{/if}">
              <i class="nav-icon fas fa-folder-open"></i>
              <p>Správce souborů</p>
            </a>
          </li>
          <li class="nav-item">
            <a n:if="$loggedUserEntity->hasGroupRight('OBJECTS')" n:href="Objects:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Objects')}active{/if}">
              <i class="nav-icon fas fa-cubes"></i>
              <p>Objekty</p>
            </a>
          </li>
          <li class="nav-item">
            <a n:if="$loggedUserEntity->hasGroupRight('LOG')"  n:href="Log:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Log')}active{/if}">
              <i class="nav-icon fas fa-history"></i>
              <p>Log</p>
            </a>
          </li>
          <li class="nav-item mt-4">
            <a n:href="Sign:out" class="nav-link text-danger">
              <i class="nav-icon fas fa-sign-out-alt"></i>
              <p>Odhlásit</p>
            </a>
          </li>
        </ul>
      </nav>
      <!-- /.sidebar-menu -->
    </div>
    <!-- /.sidebar -->
  </aside>

  <!-- Content Wrapper. Contains page content -->
  <div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <div class="content-header">
      <div class="container-fluid">
        <div class="row mb-2">
          <div class="col-sm-6">
            <h1 class="m-0">{ifset title}{include title}{/ifset}</h1>
          </div><!-- /.col -->
        </div><!-- /.row -->
      </div><!-- /.container-fluid -->
    </div>
    <!-- /.content-header -->

    <!-- Main content -->
    <div class="content">
      <div class="container-fluid">
        {snippet flashes}
          <div n:foreach="$flashes as $flash" class="alert alert-{$flash->type} alert-dismissible">
            <button type="button" class="close" data-dismiss="alert" aria-hidden="true">&times;</button>
            {$flash->message}
          </div>
        {/snippet}

        {include content}
      </div><!-- /.container-fluid -->
    </div>
    <!-- /.content -->
  </div>
  <!-- /.content-wrapper -->

  <!-- Main Footer -->
  <footer class="main-footer">
    <!-- To the right -->
    <div class="float-right d-none d-sm-inline">
      Nette & AdminLTE
    </div>
    <!-- Default to the left -->
    <strong>Copyright &copy; {date('Y')} <a href="#">SKP</a>.</strong> All rights reserved.
  </footer>
</div>
<!-- ./wrapper -->

<!-- REQUIRED SCRIPTS -->
<!-- jQuery -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<!-- Bootstrap 4 -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.6.0/js/bootstrap.bundle.min.js"></script>
<!-- AdminLTE App -->
<script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
<!-- Nette forms -->
<script src="https://nette.github.io/resources/js/3/netteForms.min.js"></script>
<!-- TinyMCE -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/6.8.2/tinymce.min.js"></script>

<!-- Naja AJAX -->
<script src="https://unpkg.com/naja@2/dist/Naja.min.js"></script>
<script>
  var s_page_name = {@$page_name};
  var s_page_title = {@$page_title};
  var s_baseUrl = {@$baseUrl};
</script>


<script n:syntax="off">
  naja.initialize();

  const initWysiwyg = () => {
    tinymce.remove('.wysiwyg');
    tinymce.init({
      selector: '.wysiwyg',
      height: 400,
      convert_urls: false,
      entity_encoding:'raw',
      verify_html:false,
      valid_elements: '*[*]',
      cleanup:false,
      apply_source_formatting:false,
      forced_root_block:false,
      allow_html_in_named_anchor: true,
      extended_valid_elements: 'svg[*],defs[*],pattern[*],desc[*],metadata[*],g[*],mask[*],path[*],line[*],polyline[*],rect[*],circle[*],ellipse[*],polygon[*],use[*],stop[*],linearGradient[*],radialGradient[*],text[*],tspan[*]',
      custom_elements: 'svg,defs,pattern,desc,metadata,g,mask,path,line,polyline,rect,circle,ellipse,polygon,use,stop,linearGradient,radialGradient,text,tspan',
      plugins: 'advlist autolink lists link image charmap preview anchor searchreplace visualblocks code fullscreen insertdatetime media table help wordcount',
      toolbar: 'undo redo | blocks | bold italic backcolor | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | removeformat | image link gallery macros | code help',
      file_picker_callback: (callback, value, meta) => {
        const textarea = document.querySelector('.wysiwyg');
        let fmUrl = textarea ? textarea.getAttribute('data-fm-url') : null;
        if (!fmUrl) {
          alert('FileManager URL is not defined.');
          return;
        }

        // Uložíme si callback pro globální message handler
        window.tinymce_callback = callback;

        // Add picker flag to URL
        const separator = fmUrl.includes('?') ? '&' : '?';
        fmUrl += separator + 'picker=1';
        if (meta.filetype === 'image') fmUrl += '&baseType=images';
        if (meta.filetype === 'file') fmUrl += '&baseType=documents';

        window.open(fmUrl, 'FileManager', 'width=1100,height=700,resizable=yes');
      },
      setup: (editor) => {
        editor.on('change', () => {
          editor.save(); // Sync with original textarea for Nette forms
        });

        const openGalleryPicker = () => {
          const textarea = document.querySelector('.wysiwyg');
          let fmUrl = textarea ? textarea.getAttribute('data-fm-url') : null;
          if (!fmUrl) {
            alert('FileManager URL is not defined.');
            return;
          }
          const separator = fmUrl.includes('?') ? '&' : '?';
          fmUrl += separator + 'picker=1&baseType=gallery';
          window.open(fmUrl, 'FileManager', 'width=1100,height=700,resizable=yes');
        };

        editor.ui.registry.addButton('gallery', {
          icon: 'gallery',
          tooltip: 'Vložit galerii',
          onAction: openGalleryPicker
        });

        editor.ui.registry.addMenuButton('macros', {
          text: 'Makra',
          fetch: (callback) => {
            let page_name = s_page_name;
            let page_title = s_page_title;
            let baseUrl = s_baseUrl;
            const items = [
              {
                type: 'menuitem',
                text: 'Vložit galerii',
                icon: 'gallery',
                onAction: openGalleryPicker
              },
              { type: 'nestedmenuitem', text: 'Systémové proměnné', items: [
                { type: 'menuitem', text: 'Název stránky', onAction: () => editor.insertContent(page_name) },
                { type: 'menuitem', text: 'Titulek stránky', onAction: () => editor.insertContent(page_title) },
                { type: 'menuitem', text: 'URL prezentace', onAction: () => editor.insertContent(baseUrl) }
              ]}
            ];
            callback(items);
          }
        });
      }
    });
  };

  </script>
  <script>
  const initCustomFileInputs = () => {
    $(document).on('change', '.custom-file-input', function() {
      let fileName = $(this).val().split('\\').pop();
      $(this).next('.custom-file-label').addClass("selected").html(fileName);
    });
  };

  const cardStatePrefix = 'card_state_';
  const setCookie = (name, value, days) => {
    let expires = "";
    if (days) {
      let date = new Date();
      date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
      expires = "; expires=" + date.toUTCString();
    }
    document.cookie = name + "=" + (value || "")  + expires + "; path=/";
  }
  const getCookie = (name) => {
    let nameEQ = name + "=";
    let ca = document.cookie.split(';');
    for(let i=0;i < ca.length;i++) {
      let c = ca[i];
      while (c.charAt(0)==' ') c = c.substring(1,c.length);
      if (c.indexOf(nameEQ) == 0) return c.substring(nameEQ.length,c.length);
    }
    return null;
  }
  const initCardPersistence = () => {
    $('.card[data-persistence-id]').each(function() {
      const id = $(this).data('persistence-id');
      const state = getCookie(cardStatePrefix + id);
      if (state === 'expanded') {
        $(this).removeClass('collapsed-card');
        $(this).find('.btn-tool i.fa-plus').removeClass('fa-plus').addClass('fa-minus');
      } else if (state === 'collapsed') {
        $(this).addClass('collapsed-card');
        $(this).find('.btn-tool i.fa-minus').removeClass('fa-minus').addClass('fa-plus');
      }
    });
  };

  $(document).on('expanded.lte.cardwidget', '.card[data-persistence-id]', function() {
    setCookie(cardStatePrefix + $(this).data('persistence-id'), 'expanded', 30);
  });
  $(document).on('collapsed.lte.cardwidget', '.card[data-persistence-id]', function() {
    setCookie(cardStatePrefix + $(this).data('persistence-id'), 'collapsed', 30);
  });

  window.addEventListener('message', function(event) {
    if (!event.data || !event.data.mceAction) return;

    if (event.data.mceAction === 'selectFile') {
      if (event.data.callback) {
        // Obshluha pro samostatné inputy (např. v editaci stránky)
        const callbackId = event.data.callback;
        const input = document.getElementById(callbackId);
        const nameDisplay = document.getElementById(callbackId + '-name');
        if (input) {
          input.value = event.data.fileId;
          $(input).trigger('change');
        }
        if (nameDisplay) {
          nameDisplay.innerText = event.data.name;
        }
      } else {
        // Obsluha pro TinyMCE (standardní file_picker)
        // Pokud existuje aktivní callback od TinyMCE, zavoláme ho
        if (window.tinymce_callback) {
          window.tinymce_callback(event.data.url);
          window.tinymce_callback = null;
        }
      }
    }

    if (event.data.mceAction === 'insertGallery') {
      if (tinymce.activeEditor) {
        tinymce.activeEditor.insertContent(event.data.shortcode);
      }
    }
  });

  document.addEventListener('DOMContentLoaded', () => {
    initWysiwyg();
    initCustomFileInputs();
    initCardPersistence();
  });
  naja.addEventListener('before', (event) => {
    $('#modal-global-confirm').modal('hide');
  });
  naja.addEventListener('success', () => {
  initWysiwyg();
  initCustomFileInputs();
  initCardPersistence();
  });

  // Globální potvrzovací modal přes Naja interaction
  naja.uiHandler.addEventListener('interaction', (event) => {
    const { element, originalEvent } = event.detail;
    if (element && element.dataset.confirm && !element.dataset.confirmed) {
      event.preventDefault(); // Zastavíme Naju

      const message = element.dataset.confirm;
      const modal = $('#modal-global-confirm');
      modal.find('#global-confirm-message').text(message);

      modal.find('#global-submit-confirm').off('click').on('click', function () {
        element.dataset.confirmed = 'true';
        element.click(); // Klikneme znovu, tentokrát už s příznakem confirmed
        delete element.dataset.confirmed;
        modal.modal('hide');
      });

      modal.modal('show');
    }
  });

  // Handler pro ne-ajaxové odkazy s data-confirm
  $(document).on('click', 'a[data-confirm]:not(.ajax)', function (e) {
    if (!this.dataset.confirmed) {
      e.preventDefault();
      const link = $(this);
      const message = link.data('confirm');
      const modal = $('#modal-global-confirm');
      modal.find('#global-confirm-message').text(message);
      modal.find('#global-submit-confirm').off('click').on('click', function () {
        link[0].dataset.confirmed = 'true';
        link[0].click();
        delete link[0].dataset.confirmed;
        modal.modal('hide');
      });
      modal.modal('show');
    }
  });
  </script>
  <!-- Global Confirm Modal -->
  <div class="modal fade" id="modal-global-confirm" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog">
      <div class="modal-content">
          <div class="modal-header bg-warning">
              <h4 class="modal-title"><i class="fas fa-exclamation-triangle"></i> Potvrdit akci</h4>
              <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
          </div>
          <div class="modal-body">
              <p id="global-confirm-message"></p>
          </div>
          <div class="modal-footer justify-content-between">
              <button type="button" class="btn btn-default" data-dismiss="modal">Zrušit</button>
              <button type="button" class="btn btn-warning" id="global-submit-confirm">Provést akci</button>
          </div>
      </div>
  </div>
  </div>

  {ifset scripts}{include scripts}{/ifset}

  </body>
  </html>
