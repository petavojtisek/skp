<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{ifset title}{include title|stripHtml} | {/ifset}SKP Admin</title>

  <!-- Google Font: Source Sans Pro -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
  <!-- Font Awesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
  <!-- Theme style -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">
</head>
<body class="hold-transition sidebar-mini">
<div class="wrapper">

  <!-- Navbar -->
  <nav class="main-header navbar navbar-expand navbar-white navbar-light">
    <!-- Left navbar links -->
    <ul class="navbar-nav">
      <li class="nav-item">
        <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
      </li>
      <li class="nav-item d-none d-sm-inline-block">
        <a n:href=":Front:Home:" class="nav-link" target="_blank">Přejít na web</a>
      </li>
    </ul>

    <!-- Right navbar links -->
    <ul class="navbar-nav ml-auto">
      {ifset $availablePresentations}
      <li class="nav-item d-flex align-items-center">
        <label class="text-muted mr-2 mb-0 d-none d-sm-inline">Aktivní prezentace:</label>
        <select class="form-control form-control-sm" style="width: auto; min-width: 150px;"
                onchange="window.location.href = this.value">
          <option n:foreach="$availablePresentations as $pid => $pres"
                  value="{link switchPresentation!, id => $pid}"
                  n:attr="selected => $loggedUserEntity->active_presentation_id == $pid">
            {$pres->presentation_name} ({$pres->domain})
          </option>
          <option n:if="!$availablePresentations" disabled selected>Žádné prezentace</option>
        </select>
      </li>
      {/ifset}
    </ul>
  </nav>
  <!-- /.navbar -->

  <!-- Main Sidebar Container -->
  <aside class="main-sidebar sidebar-dark-primary elevation-4">
    <!-- Brand Logo -->
    <a href="#" class="brand-link">
      <span class="brand-text font-weight-light">SKP Admin</span>
    </a>

    <!-- Sidebar -->
    <div class="sidebar">
      <!-- Sidebar Menu -->
      <nav class="mt-2">
        <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
          <li class="nav-item">
            <a n:href="Dashboard:, id => null, spec_param_id => null" class="nav-link {if $presenter->isLinkCurrent('Dashboard:*')}active{/if}">
              <i class="nav-icon fas fa-tachometer-alt"></i>
              <p>Dashboard</p>
            </a>
          </li>
          <li class="nav-item">
            <a n:href="Pages:, id => null, spec_param_id => null" class="nav-link {if $presenter->isLinkCurrent('Pages:*')}active{/if}">
              <i class="nav-icon fas fa-file-alt"></i>
              <p>Stránky</p>
            </a>
          </li>
          <li class="nav-item">
            <a n:href="Accounts:, id => null, spec_param_id => null" class="nav-link {if $presenter->isLinkCurrent('Accounts:*')}active{/if}">
              <i class="nav-icon fas fa-users"></i>
              <p>Účty</p>
            </a>
          </li>
          <li class="nav-item {if $presenter->isPresenter('Presentation') || $presenter->isPresenter('Config') || $presenter->isPresenter('Lookup') || $presenter->isPresenter('Template') || $presenter->isPresenter('Install') || $presenter->isPresenter('Log')}menu-open{/if}">
            <a href="#" class="nav-link {if $presenter->isPresenter('Presentation') || $presenter->isPresenter('Config') || $presenter->isPresenter('Lookup') || $presenter->isPresenter('Template') || $presenter->isPresenter('Install') || $presenter->isPresenter('Log')}active{/if}">
              <i class="nav-icon fas fa-cog"></i>
              <p>
                Nastavení
                <i class="right fas fa-angle-left"></i>
              </p>
            </a>
            <ul class="nav nav-treeview">
              <li class="nav-item">
                <a n:href="Presentation:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Presentation')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Prezentace</p>
                </a>
              </li>
              <li class="nav-item">
                <a n:href="Config:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Config')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Nastavení systému</p>
                </a>
              </li>
              <li class="nav-item">
                <a n:href="Lookup:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Lookup')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Číselníky</p>
                </a>
              </li>
              <li class="nav-item">
                <a n:href="Template:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Template')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Šablony</p>
                </a>
              </li>
              <li class="nav-item">
                <a n:href="Install:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Install')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Instalované moduly</p>
                </a>
              </li>
            </ul>
          </li>
          <li class="nav-item {if $presenter->isPresenter('Groups') || $presenter->isPresenter('ModuleRights') || $presenter->isPresenter('PageGroups')}menu-open{/if}">
            <a href="#" class="nav-link {if $presenter->isPresenter('Groups') || $presenter->isPresenter('ModuleRights') || $presenter->isPresenter('PageGroups')}active{/if}">
              <i class="nav-icon fas fa-user-shield"></i>
              <p>
                Práva
                <i class="right fas fa-angle-left"></i>
              </p>
            </a>
            <ul class="nav nav-treeview">
              <li class="nav-item">
                <a n:href="Groups:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Groups')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Skupiny</p>
                </a>
              </li>
              <li class="nav-item">
                <a n:href="ModuleRights:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('ModuleRights')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Práva modulů</p>
                </a>
              </li>
              <li class="nav-item">
                <a n:href="PageGroups:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('PageGroups')}active{/if}">
                  <i class="far fa-circle nav-icon"></i>
                  <p>Skupina stránek</p>
                </a>
              </li>
            </ul>
          </li>
          <li class="nav-item">
            <a n:href="Tools:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Tools')}active{/if}">
              <i class="nav-icon fas fa-tools"></i>
              <p>Nástroje</p>
            </a>
          </li>
          <li class="nav-item">
            <a n:href="Files:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Files')}active{/if}">
              <i class="nav-icon fas fa-folder-open"></i>
              <p>Správce souborů</p>
            </a>
          </li>
          <li class="nav-item">
            <a n:href="Objects:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Objects')}active{/if}">
              <i class="nav-icon fas fa-cubes"></i>
              <p>Objekty</p>
            </a>
          </li>
          <li class="nav-item">
            <a n:href="Log:, id => null, spec_param_id => null" class="nav-link {if $presenter->isPresenter('Log')}active{/if}">
              <i class="nav-icon fas fa-history"></i>
              <p>Log</p>
            </a>
          </li>
          <li class="nav-item mt-4">
            <a n:href="Sign:out" class="nav-link text-danger">
              <i class="nav-icon fas fa-sign-out-alt"></i>
              <p>Odhlásit</p>
            </a>
          </li>
        </ul>
      </nav>
      <!-- /.sidebar-menu -->
    </div>
    <!-- /.sidebar -->
  </aside>

  <!-- Content Wrapper. Contains page content -->
  <div class="content-wrapper">
    <!-- Content Header (Page header) -->
    <div class="content-header">
      <div class="container-fluid">
        <div class="row mb-2">
          <div class="col-sm-6">
            <h1 class="m-0">{ifset title}{include title}{/ifset}</h1>
          </div><!-- /.col -->
        </div><!-- /.row -->
      </div><!-- /.container-fluid -->
    </div>
    <!-- /.content-header -->

    <!-- Main content -->
    <div class="content">
      <div class="container-fluid">
        {snippet flashes}
          <div n:foreach="$flashes as $flash" class="alert alert-{$flash->type} alert-dismissible">
            <button type="button" class="close" data-dismiss="alert" aria-hidden="true">&times;</button>
            {$flash->message}
          </div>
        {/snippet}

        {include content}
      </div><!-- /.container-fluid -->
    </div>
    <!-- /.content -->
  </div>
  <!-- /.content-wrapper -->

  <!-- Main Footer -->
  <footer class="main-footer">
    <!-- To the right -->
    <div class="float-right d-none d-sm-inline">
      Nette & AdminLTE
    </div>
    <!-- Default to the left -->
    <strong>Copyright &copy; {date('Y')} <a href="#">SKP</a>.</strong> All rights reserved.
  </footer>
</div>
<!-- ./wrapper -->

<!-- REQUIRED SCRIPTS -->
<!-- jQuery -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<!-- Bootstrap 4 -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.6.0/js/bootstrap.bundle.min.js"></script>
<!-- AdminLTE App -->
<script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
<!-- Nette forms -->
<script src="https://nette.github.io/resources/js/3/netteForms.min.js"></script>
<!-- Naja AJAX -->
<script src="https://unpkg.com/naja@2/dist/Naja.min.js"></script>
<script>
  naja.initialize();
</script>

{ifset scripts}{include scripts}{/ifset}

</body>
</html>
