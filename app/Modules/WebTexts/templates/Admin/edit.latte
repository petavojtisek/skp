{snippet webtexts}
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Editace textu</h3>
            </div>

            <form n:name="webTextForm">
                <div class="card-body">
                    <div class="form-group">
                        <label n:name="code">Kód textu</label>
                        <input n:name="code" class="form-control" placeholder="Např. footer_contact_info">
                    </div>

                    <div class="form-group">
                        <label n:name="text">Obsah textu</label>
                        <textarea n:name="text" class="form-control editor" rows="10"></textarea>
                    </div>
                </div>

                <div class="card-footer">
                    <button n:name="send" class="btn btn-primary">Uložit</button>
                    <a href="{link list!}" class="btn btn-default">Zrušit</a>
                </div>
            </form>
        </div>
    </div>
</div>
{/snippet}
