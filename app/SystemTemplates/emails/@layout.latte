<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{ifset title}{include title|stripHtml} | {/ifset}{$SKP_NAME}</title>
    <style>
        body { font-family: 'Lato', Arial, sans-serif; line-height: 1.6; color: #333; margin: 0; padding: 0; background-color: #f4f4f4; }
        .wrapper { width: 100%; table-layout: fixed; background-color: #f4f4f4; padding-bottom: 40px; }
        .main { max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; margin-top: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .header { background-color: #ffffff; padding: 15px 20px; text-align: left; border-bottom: 1px solid #eeeeee; }
        .header table { border-collapse: collapse; margin: 0; padding: 0; }
        .header img { height: 50px; width: auto; display: block; border: 0; }
        .header h1 { margin: 0; padding: 0 0 0 12px; color: #4a7c2c; font-family: 'Montserrat', Arial, sans-serif; font-size: 18px; line-height: 1.1; vertical-align: middle; }
        .content { padding: 40px 30px; min-height: 200px; }
        .footer { background-color: #4a7c2c; color: #ffffff; padding: 30px; text-align: center; font-size: 14px; }
        .footer p { margin: 5px 0; opacity: 0.9; }
        .footer a { color: #ffffff; text-decoration: underline; }
        .btn { display: inline-block; padding: 12px 30px; background-color: #4a7c2c; color: #ffffff; text-decoration: none; border-radius: 50px; font-weight: bold; margin-top: 20px; }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="main">
            <div class="header">
                <table border="0" cellpadding="0" cellspacing="0">
                    <tr>
                        {if !empty($logoPath)}
                            <td style="vertical-align: middle;">
                                <img src="{$logoPath|noescape}" alt="Logo" style="height: 50px; width: auto;">
                            </td>
                        {/if}
                        <td style="vertical-align: middle;">
                            <h1>{$SKP_NAME}</h1>
                        </td>
                    </tr>
                </table>
            </div>
            <div class="content">
                {include content}
            </div>
            <div class="footer">
                <p><strong>{$SKP_NAME}</strong></p>
                <p>{$SKP_ADDRESS}</p>
                <p>IČO: {$SKP_ICO} | E-mail: <a href="mailto:{$SKP_EMAIL}">{$SKP_EMAIL}</a></p>
                <p style="margin-top: 15px; font-size: 12px; opacity: 0.7;">
                    Toto je automaticky generovaný e-mail, neodpovídejte na něj.
                </p>
            </div>
        </div>
    </div>
</body>
</html>
